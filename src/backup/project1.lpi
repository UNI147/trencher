<?xml version="1.0" encoding="UTF-8"?>
<CONFIG>
  <ProjectOptions>
    <Version Value="12"/>
    <PathDelim Value="\"/>
    <General>
      <SessionStorage Value="InProjectDir"/>
      <Title Value="project1"/>
      <Scaled Value="True"/>
      <ResourceType Value="res"/>
      <UseXPManifest Value="True"/>
      <XPManifest>
        <DpiAware Value="True"/>
      </XPManifest>
      <Icon Value="0"/>
    </General>
    <BuildModes>
      <Item Name="Default" Default="True"/>
    </BuildModes>
    <PublishOptions>
      <Version Value="2"/>
      <UseFileFilters Value="True"/>
    </PublishOptions>
    <RunParams>
      <FormatVersion Value="2"/>
    </RunParams>
    <RequiredPackages>
      <Item>
        <PackageName Value="LCL"/>
      </Item>
    </RequiredPackages>
    <Units>
      <Unit>
        <Filename Value="project1.lpr"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="unit1.pas"/>
        <IsPartOfProject Value="True"/>
        <ComponentName Value="Form1"/>
        <HasResources Value="True"/>
        <ResourceBaseClass Value="Form"/>
        <UnitName Value="Unit1"/>
      </Unit>
      <Unit>
        <Filename Value="models\map.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="Map"/>
      </Unit>
      <Unit>
        <Filename Value="models\player.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="Player"/>
      </Unit>
      <Unit>
        <Filename Value="core\resourcemanager.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="ResourceManager"/>
      </Unit>
      <Unit>
        <Filename Value="core\gameengine.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="GameEngine"/>
      </Unit>
      <Unit>
        <Filename Value="core\gametypes.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="GameTypes"/>
      </Unit>
      <Unit>
        <Filename Value="core\utils.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="Utils"/>
      </Unit>
      <Unit>
        <Filename Value="core\level.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="Level"/>
      </Unit>
      <Unit>
        <Filename Value="core\tileset.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="TileSet"/>
      </Unit>
      <Unit>
        <Filename Value="core\spriteset.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="SpriteSet"/>
      </Unit>
      <Unit>
        <Filename Value="core\animationcontroller.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="AnimationController"/>
      </Unit>
      <Unit>
        <Filename Value="core\spritedescriptionparser.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="SpriteDescriptionParser"/>
      </Unit>
      <Unit>
        <Filename Value="core\pathresolver.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="PathResolver"/>
      </Unit>
    </Units>
  </ProjectOptions>
  <CompilerOptions>
    <Version Value="11"/>
    <PathDelim Value="\"/>
    <Target>
      <Filename Value="project1"/>
    </Target>
    <SearchPaths>
      <IncludeFiles Value="$(ProjOutDir)"/>
      <OtherUnitFiles Value="models;core"/>
      <UnitOutputDirectory Value="lib\$(TargetCPU)-$(TargetOS)"/>
    </SearchPaths>
    <Linking>
      <Debugging>
        <DebugInfoType Value="dsDwarf3"/>
      </Debugging>
      <Options>
        <Win32>
          <GraphicApplication Value="True"/>
        </Win32>
      </Options>
    </Linking>
  </CompilerOptions>
  <Debugging>
    <Exceptions>
      <Item>
        <Name Value="EAbort"/>
      </Item>
      <Item>
        <Name Value="ECodetoolError"/>
      </Item>
      <Item>
        <Name Value="EFOpenError"/>
      </Item>
    </Exceptions>
  </Debugging>
</CONFIG>
